{
  "name": "meet",
  "version": "0.1.0",
  "description": "Local meeting transcription tool for macOS (Apple Silicon) — records mic + system audio, transcribes with whisper.cpp, outputs timestamped markdown",
  "author": "Dmitrii Diakonov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dimasmagadan/meet.git"
  },
  "keywords": [
    "meeting",
    "transcription",
    "whisper",
    "whisper-cpp",
    "macos",
    "apple-silicon",
    "audio-capture",
    "screencapturekit",
    "local-ai",
    "voice-recording"
  ],
  "type": "module",
  "bin": {
    "meet": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/main.js",
    "lint": "tsc --noEmit",
    "test": "tsc && node --test dist/**/*.test.js"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
